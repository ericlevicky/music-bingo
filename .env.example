# Spotify Developer App credentials
# Create an app at https://developer.spotify.com/dashboard
SPOTIFY_CLIENT_ID=your_spotify_client_id_here
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret_here

# Optional: override the Spotify redirect URI (defaults to <scheme>://<host>/auth/spotify/callback)
# derived from the incoming request, which is correct for most deployments).
# Register the same value in your Spotify app's "Redirect URIs" settings.
# SPOTIFY_REDIRECT_URI=http://localhost:3000/auth/spotify/callback

# Google OAuth credentials
# Create an app at https://console.cloud.google.com/
# Enable the "Google People API" and create OAuth 2.0 credentials
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# Must be an Authorised redirect URI in your Google OAuth app settings
GOOGLE_REDIRECT_URI=http://localhost:3000/auth/google/callback

# Random string used to sign session cookies – change this in production!
SESSION_SECRET=change-me-to-a-long-random-string

# Server port (optional, defaults to 3000)
PORT=3000
